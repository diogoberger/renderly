# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database (Railway provides this automatically on deploy) ─────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/renderly

# ─── Stripe (get these from dashboard.stripe.com → Developers → API keys) ────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe dashboard (Products section)
# Run `node src/db/stripe-setup.js` after adding your secret key to auto-create them
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_SCALE=price_...

# ─── App ──────────────────────────────────────────────────────────────────────
# URL of your deployed dashboard (used in Stripe redirect URLs)
DASHBOARD_URL=http://localhost:3000
API_URL=http://localhost:3001
